{
  "entities": {
    "PatientRecord": {
      "title": "Patient Record",
      "description": "A comprehensive clinical record for a patient assessment.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the record." },
        "name": { "type": "string", "description": "Full name of the patient.", "minLength": 2, "maxLength": 100 },
        "age": { "type": "string", "description": "Age of the patient.", "pattern": "^[0-9]{1,3}$" },
        "gender": { "type": "string", "enum": ["male", "female", "other", ""] },
        "caseNo": { "type": "string" },
        "clinician": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "neurologicalDiagnosis": { "type": "string" },
        "fdaData": {
          "type": "object",
          "description": "Standardized FDA-2 scores (0-4)."
        },
        "fdaObservations": {
          "type": "object",
          "description": "Clinical observations for each FDA-2 section."
        }
      },
      "required": ["id", "name", "age", "gender"]
    }
  },
  "firestore": {
    "/users/{userId}/records/{recordId}": {
      "schema": "PatientRecord",
      "description": "User-owned clinical records."
    }
  }
}
